      "enabled": true,
      "firstName": "Testuser",
      "lastName": "User",
      "realmRoles": [
        "user"
      ],
      "username": "testuser"
    },
    {
      "credentials": [
        {
          "temporary": false,
          "type": "password",
          "value": "password"
        }
      ],
      "email": "adminuser@test.com",

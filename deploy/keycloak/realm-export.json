{
  "accessTokenLifespan": 3600,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "saas-backend",
      "directAccessGrantsEnabled": true,
      "enabled": true,
      "name": "lightweight-saas-backend API",
      "protocol": "openid-connect",
      "publicClient": false,
      "redirectUris": [
        "http://localhost:8080/*"
      ],
      "secret": "saas-backend-secret",
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "webOrigins": [
        "http://localhost:8080"
      ]
    },
    {
      "clientId": "saas-backend-admin",
      "description": "Service-account client used by the API to call Keycloak's Admin REST API. No user-facing flows.",
      "directAccessGrantsEnabled": false,
      "enabled": true,
      "name": "lightweight-saas-backend — Identity Admin",
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "saas-backend-admin-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false
    },
    {
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/dev/auth+http://localhost:8080/admin"
      },
      "clientId": "saas-dev-playground",
      "description": "DEV-ONLY public PKCE client used by both the legacy /dev/auth playground and the new /admin console. Disable in non-local environments.",
      "directAccessGrantsEnabled": false,
      "enabled": true,
      "name": "lightweight-saas-backend — Dev Auth Playground + Admin Console",
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": [
        "http://localhost:8080/dev/auth",
        "http://localhost:8080/admin"
      ],
      "serviceAccountsEnabled": false,
      "standardFlowEnabled": true,
      "webOrigins": [
        "http://localhost:8080"
      ]
    }
  ],
  "displayName": "lightweight-saas-backend",
  "duplicateEmailsAllowed": false,
  "editUsernameAllowed": false,
  "enabled": true,
  "loginWithEmailAllowed": true,
  "realm": "saas",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "description": "realm role: admin",
        "name": "admin"
      },
      {
        "description": "realm role: user",
        "name": "user"
      }
    ]
  },
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "no-reply@saas.local",
    "fromDisplayName": "lightweight-saas-backend",
    "auth": "false",
    "starttls": "false",
    "ssl": "false"
  },
  "sslRequired": "none",
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "users": [
    {
      "credentials": [
        {
          "temporary": false,

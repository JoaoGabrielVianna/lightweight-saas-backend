# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=saas_db
DB_SSL_MODE=disable
DB_URL=postgres://user:password@localhost:5432/saas_db

# Server Configuration
PORT=8080
ENV=development
LOG_LEVEL=debug

# HTTP Framework Configuration
GIN_LOG_ENABLED=true
GIN_ACCESS_LOG_ENABLED=true

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email Configuration (Optional, for phase 2)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# External Services (For future phases)
# STRIPE_API_KEY=your_stripe_key
# REDIS_URL=redis://localhost:6379
